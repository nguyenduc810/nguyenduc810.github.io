source 'https://rubygems.org'

# Remove the github-pages gem since you're using Jekyll 4.x
# gem 'github-pages', group: :jekyll_plugins

# Define Jekyll version once
gem 'jekyll', '~> 4.3.4'

group :jekyll_plugins do
    gem 'classifier-reborn'
    gem 'jekyll-archives'
    gem 'classifier-reborn'
    gem 'jekyll-archives'
    gem 'jekyll-email-protect'
    gem 'jekyll-feed'
    gem 'jekyll-get-json'
    gem 'jekyll-imagemagick'
    gem 'jekyll-jupyter-notebook'
    gem 'jekyll-link-attributes'
    gem 'jekyll-minifier'
    gem 'jekyll-paginate-v2'
    gem 'jekyll-regex-replace'
    gem 'jekyll-scholar'
    gem 'jekyll-sitemap'
    gem 'jekyll-tabs'
    gem 'jekyll-toc', '~> 0.19.0'  # Moved into plugins group
    gem 'jekyll-twitter-plugin'
    gem 'jemoji'
    gem 'terser'
    gem 'unicode_utils'
    gem 'webrick'
end

